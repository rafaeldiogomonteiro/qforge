# QForge Backend (.env)
# Copia este ficheiro para backend/.env e preenche os valores.

# Servidor
PORT=4000

# Base de dados (MongoDB)
# Exemplo Atlas:
# MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority

# Auth (JWT)
JWT_SECRET=change-me

# CORS (origens permitidas) — lista separada por vírgulas
ALLOWED_ORIGINS=http://localhost:5173,https://qforge.maruqes.com,https://www.qforge.maruqes.com

# IA (opcional) — configura UM dos provedores
GROQ_API_KEY=

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto
# OPENROUTER_FAST_MODEL=gryphe/mythomax-l2-13b:free
OPENROUTER_FAST_MODEL=
# Lista separada por vírgulas; se vazio, o backend usa defaults internos.
OPENROUTER_FALLBACK_MODELS=
OPENROUTER_SITE=http://localhost:5173
OPENROUTER_TITLE=QForge

# IA — timeouts e retries (opcionais)
# Mantém abaixo do timeout do proxy/reverse para evitar 504 sem CORS.
AI_CONNECT_TIMEOUT_MS=10000
AI_REQUEST_TIMEOUT_MS=45000
AI_HEADERS_TIMEOUT_MS=30000
AI_BODY_TIMEOUT_MS=45000
AI_REQUEST_RETRIES=0
AI_RETRY_DELAY_MS=1500
AI_MAX_TOKENS=2048
